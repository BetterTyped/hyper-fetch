{
  "name": "hyper-fetch",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "install-peers": "node ./scripts/install-peers",
    "prepare": "pnpm install-peers && pnpm husky install",
    "reset": "pnpm nx reset",
    "start": "pnpm reset && nx run-many --target=start --parallel=10 --projects='packages/*'",
    "start:app": "pnpm reset && nx serve",
    "build": "pnpm reset && nx run-many --target=build --parallel=2 --skip-nx-cache --projects='packages/*'",
    "build:docs": "cd documentation && pnpm install && pnpm build",
    "test": "nx run-many --target=test --parallel=1 --skip-nx-cache --projects='packages/*' --exclude=firebase,firebase-admin",
    "lint": "nx run-many --target=lint --parallel=3 --skip-nx-cache --projects='packages/*'",
    "format": "nx run-many --target=format --parallel=3 --skip-nx-cache --projects='packages/*'",
    "typecheck": "nx run-many --target=typecheck --parallel=2 --skip-nx-cache --projects='packages/*'",
    "release": "nx run-many --target=release --parallel=1 --skip-nx-cache --projects='packages/*'",
    "nx:upgrade": "npx nx migrate latest",
    "update-version": "node ./scripts/update-package-version.js"
  },
  "dependencies": {
    "@nx/js": "22.6.5",
    "@nx/next": "22.6.5",
    "@nx/react": "22.6.5",
    "@nx/vite": "22.6.5",
    "@nx/web": "22.6.5",
    "@nx/workspace": "22.6.5",
    "jest-extended": "^7.0.0",
    "lucide-react": "^0.476.0",
    "nx": "22.6.5",
    "react-router-dom": "6.30.3",
    "regenerator-runtime": "0.13.7",
    "use-immer": "^0.11.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.0.0",
    "@commitlint/config-conventional": "^17.0.2",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "^5.8.4",
    "@mui/material": "^5.8.4",
    "@testing-library/dom": "^10.1.0",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "18.16.9",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@typescript/native-preview": "latest",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "commitlint": "^17.0.2",
    "core-js": "^3.6.5",
    "docusaurus-docgen": "^1.1.4",
    "executioner": "^2.0.1",
    "husky": "8.0.1",
    "lint-staged": "^13.0.1",
    "msw": "^2.13.2",
    "next": "14.2.28",
    "notistack": "^2.0.5",
    "oxfmt": "latest",
    "oxlint": "latest",
    "react": "19.1.0",
    "react-countdown": "^2.3.2",
    "react-dom": "19.1.0",
    "react-test-renderer": "18.2.0",
    "semantic-release": "^25.0.2",
    "terminal-link": "^3.0.0",
    "typescript": "5.9.3",
    "undici": "6.19.0",
    "vite": "8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "^4.1.4"
  },
  "config": {
    "commitizen": {
      "path": "git-cz"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BetterTyped/hyper-fetch.git"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  },
  "keywords": [
    "fetch",
    "xhr",
    "requests",
    "js",
    "graphql",
    "fetcher",
    "queue",
    "offline",
    "persistence",
    "cache",
    "builder",
    "command",
    "swr",
    "websockets",
    "ajax",
    "sse",
    "sockets",
    "events"
  ],
  "msw": {
    "workerDirectory": "src"
  },
  "peerDependencies": {
    "axios": "*",
    "events": "*",
    "firebase": "*",
    "firebase-admin": "*",
    "firebase-tools": "*",
    "graphql": "*",
    "graphql-tag": "^2.12.6",
    "http": "*",
    "stream": "*"
  },
  "packageManager": "pnpm@10.11.0"
}
