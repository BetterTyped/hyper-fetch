{
  // This file is not used in compilation. It is here just for a nice editor experience.
  // Mirrors @docusaurus/tsconfig locally so `paths` are relative to this directory without `baseUrl`.
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "module": "esnext",
    "noEmit": true,
    "paths": {
      "@site/*": ["./*"]
    },
    "skipLibCheck": true
  }
}
