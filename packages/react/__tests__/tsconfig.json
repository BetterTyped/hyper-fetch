{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["vitest/globals", "jest-extended", "@testing-library/jest-dom", "@types/node"],
    "paths": {
      "helpers": ["../src/helpers"],
      "helpers/*": ["../src/helpers/*"],
      "hooks": ["../src/hooks"],
      "hooks/*": ["../src/hooks/*"],
      "provider": ["../src/provider"],
      "provider/*": ["../src/provider/*"],
      "utils": ["../src/utils"],
      "utils/*": ["../src/utils/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "../../../global.d.ts", "../../../vitest.d.ts"],
  "exclude": ["node_modules"]
}
