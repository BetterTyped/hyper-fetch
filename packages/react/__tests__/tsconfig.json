{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["dom", "dom.iterable", "ESNext"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["vitest/globals", "jest-extended", "@testing-library/jest-dom", "@types/node"],
    "baseUrl": "../src",
    "paths": {
      "hooks/*": ["hooks/*"],
      "helpers/*": ["helpers/*"],
      "utils/*": ["utils/*"],
      "provider": ["provider"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "../../../global.d.ts", "../../../vitest.d.ts"]
}
