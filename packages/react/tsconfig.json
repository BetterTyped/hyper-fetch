{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "paths": {
      "helpers": ["./src/helpers"],
      "helpers/*": ["./src/helpers/*"],
      "hooks": ["./src/hooks"],
      "hooks/*": ["./src/hooks/*"],
      "provider": ["./src/provider"],
      "provider/*": ["./src/provider/*"],
      "utils": ["./src/utils"],
      "utils/*": ["./src/utils/*"]
    }
  },
  "exclude": ["node_modules", "dist", "vite.config.ts", "__tests__"]
}
