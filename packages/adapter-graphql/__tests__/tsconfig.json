{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["vitest/globals", "jest-extended", "@types/node"],
    "paths": {
      "adapter": ["../src/adapter"],
      "adapter/*": ["../src/adapter/*"],
      "@hyper-fetch/graphql": ["../src"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "../../../global.d.ts", "../../../vitest.d.ts"],
  "exclude": ["node_modules"]
}
