{
  "name": "@hyper-fetch/firebase",
  "version": "0.0.0",
  "description": "First class Firebase Web adapter for Hyper Fetch",
  "author": "Maciej Pyrc <maciekpyrc@gmail.com>, Kacper Skawina <kacper.skawina@gmail.com>",
  "homepage": "https://hyperfetch.bettertyped.com/",
  "license": "Apache-2.0",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "source": "src/index.ts",
  "scripts": {
    "test": "firebase emulators:exec 'npx vitest run'",
    "coverage": "firebase emulators:exec 'npx vitest run --coverage'",
    "start": "yarn build && npx run-when-changed --watch 'src/**/*.ts' --exec 'yarn build'",
    "start:emulator": "firebase emulators:start --project demo-test --only firestore,database",
    "build": "vite build",
    "lint": "eslint . --ext .js,.jsx,.tsx,.ts --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false && tsc --noEmit -p __tests__/tsconfig.json",
    "tests": "firebase emulators:exec 'npx vitest run'",
    "release": "yarn semantic-release --extends ../../release.config.js  -t 'hyper-fetch-firebase-v${version}'"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BetterTyped/hyper-fetch.git",
    "directory": "packages/adapter-firebase"
  },
  "bugs": {
    "url": "https://github.com/BetterTyped/hyper-fetch/issues"
  },
  "peerDependencies": {
    "@hyper-fetch/core": "*",
    "@hyper-fetch/sockets": "*",
    "firebase": "*",
    "firebase-tools": "*"
  },
  "peerDependenciesMeta": {
    "firebase": {
      "optional": true
    },
    "firebase-tools": {
      "optional": true
    }
  },
  "devDependencies": {
    "firebase": "^9.21.0",
    "firebase-tools": "^11.23.1",
    "wait-for-expect": "^3.0.2"
  },
  "keywords": [
    "firebase",
    "firestore",
    "realtime",
    "storage",
    "database",
    "authentication"
  ]
}
