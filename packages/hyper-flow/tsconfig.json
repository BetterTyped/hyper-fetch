{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "paths": {
      "@/*": ["./src/frontend/*"],
      "@app/*": ["./src/app/*"],
      "app/*": ["./src/app/*"],
      "@server/*": ["./src/server/*"],
      "@shared/*": ["./src/shared/*"],
      "@testing/*": ["./__tests__/*"]
    }
  },
  "include": ["src/**/*", "electron.d.ts", "vite-env.d.ts", "forge.env.d.ts"],
  "exclude": ["node_modules", "dist", "vite.config.mts", "__tests__", "configs"]
}
