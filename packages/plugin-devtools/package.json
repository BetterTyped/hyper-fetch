{
  "name": "@hyper-fetch/plugin-devtools",
  "version": "0.0.0",
  "description": "Socket devtool plugin for HyperFetch",
  "author": "Maciej Pyrc <maciekpyrc@gmail.com>, Kacper Skawina <kacper.skawina@gmail.com>",
  "homepage": "https://hyperfetch.bettertyped.com/",
  "license": "Apache-2.0",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "source": "src/index.ts",
  "scripts": {
    "test": "vitest run",
    "start": "pnpm build && npx run-when-changed --watch 'src/**/*.{ts,tsx}' --exec 'pnpm build'",
    "build": "vite build",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "typecheck": "tsgo --noEmit --emitDeclarationOnly false && tsgo --noEmit -p __tests__/tsconfig.json",
    "tests": "pnpm lint-staged",
    "release": "pnpm semantic-release --extends ../../release.config.js  -t 'plugin-devtools-hyper-fetch-v${version}'"
  },
  "peerDependencies": {
    "@hyper-fetch/core": "*",
    "@hyper-fetch/sockets": "*"
  },
  "peerDependenciesMeta": {
    "@hyper-fetch/core": {
      "optional": true
    },
    "@hyper-fetch/sockets": {
      "optional": true
    }
  },
  "devDependencies": {
    "superjson": "2.2.1",
    "wait-for-expect": "^3.0.2",
    "ws": "^8.18.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "vitest related --run --passWithNoTests"
    ]
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BetterTyped/hyper-fetch.git",
    "directory": "packages/plugin-devtools"
  },
  "bugs": {
    "url": "https://github.com/BetterTyped/hyper-fetch/issues"
  },
  "keywords": [
    "devtools",
    "hyper-fetch"
  ]
}
