{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "proseWrap": "always",
  "arrowParens": "always",
  "sortPackageJson": false,
  "sortImports": {
    "groups": [
      ["builtin", "external"],
      { "newlinesBetween": true },
      ["internal", "subpath", "parent", "sibling", "index"]
    ],
    "newlinesBetween": true,
    "internalPattern": ["@/", "@hype-stack/"]
  },
  "ignorePatterns": ["/dist", "**/coverage", "/.nx/cache", "/.nx/workspace-data"]
}
